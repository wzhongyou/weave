# Graphflow LLM 配置文件
# cp llmgate.toml.example llmgate.toml，然后填入你的 API key。
#
# 两种配置方式：
#   1. 直接写入 key：  key = "sk-xxx"
#   2. 环境变量引用：  key = "${DEEPSEEK_KEY}"
#
# 用真实模型运行 Agent Demo：
#   go run ./examples/agent_demo/ -config config/llmgate.toml -model deepseek

# ── 供应商（取消注释你要用的那个） ─────────────────────────────
[[providers]]
name = "deepseek"
key = "${DEEPSEEK_KEY}"

# [[providers]]
# name = "openai"
# key = "${OPENAI_KEY}"
#
# [[providers]]
# name = "anthropic"
# key = "${ANTHROPIC_KEY}"
#
# [[providers]]
# name = "glm"
# key = "${GLM_KEY}"

# ── 路由策略（可选） ──────────────────────────────────────────
[strategy]
primary = "deepseek"
# fallback = ["glm", "minimax"]
